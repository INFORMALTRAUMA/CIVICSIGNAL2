# Copy to mobile/.env and set values. Restart Expo after changes (use `npx expo start -c` if env still missing).
#
# Supabase: Dashboard → Project Settings → API
#   - Project URL  → EXPO_PUBLIC_SUPABASE_URL
#   - anon public  → EXPO_PUBLIC_SUPABASE_ANON_KEY

# Next API: iOS Simulator can use localhost. Physical device → http://192.168.x.x:3000 (your Mac/PC LAN IP).
# Android emulator: localhost is rewritten to 10.0.2.2 automatically in mobile/lib/config.ts
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
